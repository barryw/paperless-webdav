# Required settings
PAPERLESS_URL=http://your-paperless-instance:8000

# Hostname for TLS certificate (default: localhost)
# Set this to the hostname you'll use to access the service
# SITE_HOST=paperless-dav.example.com
SECRET_KEY=generate-a-random-32-char-string-here

# Generate with: python -c "import secrets; import base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=your-base64-encoded-32-byte-key

# Auth mode: "paperless" (default) or "oidc"
AUTH_MODE=paperless

# OIDC settings (only needed if AUTH_MODE=oidc)
# OIDC_ISSUER=https://your-authentik-instance/application/o/paperless-webdav/
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
